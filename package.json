{
  "name": "x-matrix",
  "version": "3.9.0",
  "description": "A proof-carrying skill matrix runtime for verifiable onchain agent workflows on X Layer.",
  "type": "module",
  "bin": {
    "trademesh": "./dist/bin/trademesh.js"
  },
  "files": [
    "dist",
    "skills",
    "profiles",
    "docs",
    "rules",
    "doctrines"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bin/trademesh.js",
    "doctor": "npm run build --silent && node dist/bin/trademesh.js doctor",
    "demo:flow": "pnpm build && node scripts/demo-flow.mjs",
    "archive:dev-state": "node scripts/archive-dev-state.mjs",
    "skills": "npm run build --silent && node dist/bin/trademesh.js skills ls",
    "test": "pnpm build && node --test --test-concurrency=1 tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "undici": "^7.25.0"
  }
}
